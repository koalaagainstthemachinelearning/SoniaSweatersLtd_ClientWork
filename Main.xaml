roups(3).Value)&#xA;                    Dim r4 As Integer = CInt(ratioMatch.Groups(4).Value)&#xA;                    Dim rTotal As Integer = r1 + r2 + r3 + r4&#xA;                    qty36   = CInt(Math.Round(CDbl(totalQty) / rTotal * r1))&#xA;                    qty3840 = CInt(Math.Round(CDbl(totalQty) / rTotal * r2))&#xA;                    qty4244 = CInt(Math.Round(CDbl(totalQty) / rTotal * r3))&#xA;                    qty4648 = CInt(Math.Round(CDbl(totalQty) / rTotal * r4))&#xA;                    Console.WriteLine(&quot;Ratio found: &quot; &amp; qty36.ToString &amp; &quot;/&quot; &amp; qty3840.ToString &amp; &quot;/&quot; &amp; qty4244.ToString &amp; &quot;/&quot; &amp; qty4648.ToString)&#xA;                    Exit For&#xA;                End If&#xA;            End If&#xA;        Next&#xA;&#xA;        If qty36 = 0 AndAlso qty3840 = 0 Then&#xA;            Console.WriteLine(&quot;WARNING: Ratio not found for &quot; &amp; styleRef &amp; &quot; | &quot; &amp; color)&#xA;        End If&#xA;&#xA;        ' ── Append row to dt_AllJobs ─────────────────────────&#xA;        Console.WriteLine(&quot;Adding row to dt...&quot;)&#xA;        Dim newRow As DataRow = out_dt.NewRow()&#xA;        newRow(&quot;PO_No&quot;)            = out_PO_No&#xA;        newRow(&quot;Style_Ref&quot;)        = styleRef&#xA;        newRow(&quot;Color&quot;)            = color&#xA;        newRow(&quot;Unit_Price&quot;)       = price&#xA;        newRow(&quot;Total_Qty&quot;)        = totalQty.ToString&#xA;        newRow(&quot;Qty_36&quot;)           = qty36.ToString&#xA;        newRow(&quot;Qty_38_40&quot;)        = qty3840.ToString&#xA;        newRow(&quot;Qty_42_44&quot;)        = qty4244.ToString&#xA;        newRow(&quot;Qty_46_48&quot;)        = qty4648.ToString&#xA;        newRow(&quot;ETD&quot;)              = out_ETD&#xA;        newRow(&quot;PO_Date&quot;)          = out_PODate&#xA;        newRow(&quot;Delivery_Country&quot;) = out_Country&#xA;        out_dt.Rows.Add(newRow)&#xA;        Console.WriteLine(&quot;Row added successfully&quot;)&#xA;    Next&#xA;&#xA;Catch ex As Exception&#xA;    Dim fullError As String = &quot;Message: &quot; &amp; ex.Message&#xA;    If ex.InnerException IsNot Nothing Then&#xA;        fullError = fullError &amp; &quot; | Inner: &quot; &amp; ex.InnerException.Message&#xA;    End If&#xA;    If ex.InnerException IsNot Nothing AndAlso ex.InnerException.InnerException IsNot Nothing Then&#xA;        fullError = fullError &amp; &quot; | Inner2: &quot; &amp; ex.InnerException.InnerException.Message&#xA;    End If&#xA;    Console.WriteLine(&quot;EXCEPTION: &quot; &amp; fullError)&#xA;    Throw New Exception(fullError)&#xA;End Try" DisplayName="Invoke Code" sap:VirtualizedContainerService.HintSize="416,188" sap2010:WorkflowViewState.IdRef="InvokeCode_1">
